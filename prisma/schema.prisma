// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Factura {
  id        Int      @id @default(autoincrement())
  clienteId Int
  fecha     DateTime @default(now())
  productos Json
  subtotal  Float
  iva       Float
  total     Float
}
